# Runtime secrets for the phosphor relay container.
# Copy to .env alongside docker-compose.yml and fill in the values.
# ADDR, BASE_URL, and REDIS_URL are set in docker-compose.yml.

# Microsoft OIDC
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Google OIDC
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple OIDC
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# HMAC secret for signing API keys — keep stable so keys survive restarts
API_KEY_SECRET=
