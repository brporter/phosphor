                    <TextBlock
                        FontFamily="Cascadia Mono, Consolas"
                        FontSize="14"
                        LineHeight="16"
                        Foreground="{StaticResource PhosphorGreenBrush}"
                        IsTextSelectionEnabled="False"
                        TextAlignment="Left"
