<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Phosphor.Views.SessionListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Phosphor.Models"
    xmlns:helpers="using:Phosphor.Helpers">

    <Page.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </Page.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
            <TextBlock Text="Sessions" FontSize="28" FontWeight="SemiBold" />
            <Button Content="&#x27F3;" Click="Refresh_Click" ToolTipService.ToolTip="Refresh"
                    VerticalAlignment="Center" />
        </StackPanel>

        <!-- Error bar -->
        <InfoBar x:Name="ErrorBar" Grid.Row="0" IsOpen="False" Severity="Error"
                 IsClosable="True" Margin="0,48,0,0" />

        <!-- Loading -->
        <ProgressRing x:Name="LoadingRing" Grid.Row="1" IsActive="False"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />

        <!-- Empty state -->
        <StackPanel x:Name="EmptyState" Grid.Row="1" Visibility="Collapsed"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
            <TextBlock Text="No active sessions" FontSize="18"
                       HorizontalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock Text="Start a session with the Phosphor CLI:" FontSize="13"
                       HorizontalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            <Border Background="{StaticResource PhosphorTerminalBgBrush}"
                    CornerRadius="6" Padding="16,10">
                <TextBlock Text="phosphor --relay wss://your-relay -- bash"
                           FontFamily="{StaticResource TerminalFontFamily}" FontSize="13"
                           Foreground="{StaticResource PhosphorGreenBrush}" />
            </Border>
        </StackPanel>

        <!-- Session list -->
        <ListView x:Name="SessionList" Grid.Row="1"
                  SelectionMode="None" IsItemClickEnabled="True"
                  ItemClick="SessionList_ItemClick">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:SessionData">
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1" CornerRadius="8"
                            Padding="16,12" Margin="0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Hostname + command -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{x:Bind Hostname}" FontSize="14" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Bind Command}" FontSize="13"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>

                            <!-- Badges -->
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                <!-- Mode badge -->
                                <Border Style="{StaticResource BadgePty}"
                                        Visibility="{x:Bind IsPty, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="PTY" FontSize="10"
                                               Foreground="{StaticResource PhosphorGreenBrush}" />
                                </Border>
                                <Border Style="{StaticResource BadgePipe}"
                                        Visibility="{x:Bind IsPty, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}">
                                    <TextBlock Text="PIPE" FontSize="10"
                                               Foreground="{StaticResource PhosphorCyanBrush}" />
                                </Border>

                                <!-- Encrypted badge -->
                                <Border Style="{StaticResource BadgeEncrypted}"
                                        Visibility="{x:Bind Encrypted, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="&#x1F512;" FontSize="10" />
                                </Border>

                                <!-- Viewer count -->
                                <TextBlock FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                    <Run Text="&#x1F441;" /><Run Text=" " /><Run Text="{x:Bind ViewerCount}" />
                                </TextBlock>
                            </StackPanel>

                            <!-- Session ID + dimensions -->
                            <TextBlock Grid.Row="1" Grid.Column="0" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       Margin="0,4,0,0">
                                <Run Text="{x:Bind Cols}" />x<Run Text="{x:Bind Rows}" /> · <Run Text="{x:Bind Id}" />
                            </TextBlock>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>
    </Grid>
</Page>
