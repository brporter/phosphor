<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Phosphor accent colors -->
    <Color x:Key="PhosphorGreen">#00FF41</Color>
    <Color x:Key="PhosphorCyan">#00E5FF</Color>
    <Color x:Key="PhosphorAmber">#FFB000</Color>
    <Color x:Key="PhosphorRed">#FF3333</Color>
    <Color x:Key="PhosphorBgDark">#1A1A2E</Color>
    <Color x:Key="PhosphorTerminalBg">#050808</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PhosphorGreenBrush" Color="{StaticResource PhosphorGreen}" />
    <SolidColorBrush x:Key="PhosphorCyanBrush" Color="{StaticResource PhosphorCyan}" />
    <SolidColorBrush x:Key="PhosphorAmberBrush" Color="{StaticResource PhosphorAmber}" />
    <SolidColorBrush x:Key="PhosphorRedBrush" Color="{StaticResource PhosphorRed}" />
    <SolidColorBrush x:Key="PhosphorTerminalBgBrush" Color="{StaticResource PhosphorTerminalBg}" />

    <!-- Override system accent -->
    <SolidColorBrush x:Key="SystemControlHighlightAccentBrush" Color="{StaticResource PhosphorGreen}" />
    <SolidColorBrush x:Key="SystemAccentColor" Color="{StaticResource PhosphorGreen}" />

    <!-- Card surfaces -->
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#0A0A0A" Opacity="0.6" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="#FFFFFF" Opacity="0.06" />

    <!-- Badge styles -->
    <Style x:Key="BadgePty" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource PhosphorGreen}" Opacity="0.15" />
            </Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="8,2" />
    </Style>

    <Style x:Key="BadgePipe" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource PhosphorCyan}" Opacity="0.15" />
            </Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="8,2" />
    </Style>

    <Style x:Key="BadgeEncrypted" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource PhosphorCyan}" Opacity="0.15" />
            </Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="8,2" />
    </Style>

    <Style x:Key="BadgeError" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource PhosphorRed}" Opacity="0.15" />
            </Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="8,2" />
    </Style>

    <!-- Typography -->
    <FontFamily x:Key="TerminalFontFamily">Cascadia Code, Fira Code, Consolas</FontFamily>
    <FontFamily x:Key="AppFontFamily">Segoe UI Variable, Segoe UI</FontFamily>

    <!-- NavigationView overrides for green accent -->
    <SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground" Color="{StaticResource PhosphorGreen}" />

</ResourceDictionary>
