# Relay server configuration
# Copy this file to .env and fill in values as needed.

# Server
ADDR=:8080
BASE_URL=http://localhost:8080
DEV_MODE=1

# Redis (leave empty for in-memory)
REDIS_URL=

# Microsoft OIDC
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Google OIDC
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple OIDC
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
